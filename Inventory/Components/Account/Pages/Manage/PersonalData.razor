@page "/Account/Manage/PersonalData"

@inject IdentityUserAccessor UserAccessor

<PageTitle>Персональные данные</PageTitle>

<StatusMessage />
<h3>Персональные данные</h3>

<div class="row">
    <div class="col-md-6">
        <p>Ваша учетная запись содержит личные данные, которые вы нам дали. Эта страница позволяет загружать или удалять эти данные.</p>
        <p>
            <strong>Удаление этих данных навсегда удалит вашу учетную запись, и это не может быть восстановлено.</strong>
        </p>
        <form action="Account/Manage/DownloadPersonalData" method="post">
            <AntiforgeryToken />
            <button class="btn btn-primary" type="submit">Загрузить</button>
        </form>
        <p class="mt-2">
            <a href="Account/Manage/DeletePersonalData" class="btn btn-danger">Удалить</a>
        </p>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        _ = await UserAccessor.GetRequiredUserAsync(HttpContext);
    }
}
