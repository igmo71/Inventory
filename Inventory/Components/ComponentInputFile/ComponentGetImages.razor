@using Inventory.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<Inventory.Data.ApplicationDbContext> DbFactory

@if (images is null)
{
    <div class="spinner-border mb-3" role="status">
        <span class="visually-hidden">Загрузка...</span>
    </div>
}
else
{
    foreach (var image in images)
    {
        <div>
            <div>@image.FileName</div>
            <img src="@($"/images/{image.EquipmentOrderId}_{image.TrustedFileName}.jpg")" />
        </div>
    }
}
<img src="/images/1.jpg" />


@code {
    [Parameter]
    public string? Id { get; set; }

    private List<EquipmentOrderFile>? images;

    protected override void OnInitialized()
    {
        using var context = DbFactory.CreateDbContext();
        images = context.EquipmentOrderFiles
            .Where(e => e.EquipmentOrderId == Id)
            .ToList();
    }
}