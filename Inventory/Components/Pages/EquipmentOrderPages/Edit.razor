@page "/equipmentorders/edit"

@using Inventory.Application
@using Inventory.Application.EquipmentOrderServices
@using Inventory.Application.LocationServices
@using Inventory.Components.ComponentAppFile
@using Inventory.Data
@using Inventory.Domain
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity

@inject NavigationManager NavigationManager
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IEquipmentOrderService Service
@inject IEquipmentService EquipmentService
@inject ISerialNumberService SerialNumberService
@inject ILocationService LocationService

@attribute [Authorize(Roles = "Manager")]

<PageTitle>Изменить</PageTitle>

<h1>Изменить</h1>

<h2>Ордер на Оборудование</h2>
<hr />
@if (EquipmentOrder is null)
{
    <p><em>Загрузка...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="EquipmentOrder" OnValidSubmit="UpdateEquipmentOrder" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert" />

                <input type="hidden" name="EquipmentOrder.Id" value="@EquipmentOrder.Id" />
                                
                <div class="form-floating mb-3">
                    <InputText id="number" @bind-Value="EquipmentOrder.Number" class="form-control" />
                    <label for="number" class="form-label">Номер:</label>
                    <ValidationMessage For="() => EquipmentOrder.Number" class="text-danger" />
                </div>
               
                <div class="form-floating mb-3">
                    <InputDate id="datetime" @bind-Value="EquipmentOrder.DateTime" class="form-control" />
                    <label for="datetime" class="form-label">Дата:</label>
                    <ValidationMessage For="() => EquipmentOrder.DateTime" class="text-danger" />
                </div>
                
                <div class="form-floating mb-3">
                    @if (EquipmentOrder.Author != null)
                    {
                        <InputText id="authorid" @bind-Value="EquipmentOrder.Author.Name" class="form-control" />
                    }
                    <label for="authorid" class="form-label">Автор:</label>
                    <ValidationMessage For="() => EquipmentOrder.AuthorId" class="text-danger" />
                </div>
                
                <div class="form-floating mb-3">
                    <InputSelect id="equipmentid" @bind-Value="EquipmentOrder.EquipmentId" class="form-control" disabled="@isEquipmentIdDisabled">
                        <option value="">- Выберите -</option>
                        @foreach (var equip in equipment)
                        {
                            <option value="@equip.Id">@equip.Name</option>
                        }
                    </InputSelect>
                    <label for="equipmentid" class="form-label">Оборудование:</label>
                    <ValidationMessage For="() => EquipmentOrder.EquipmentId" class="text-danger" />
                </div>
                
                <div class="form-floating mb-3">
                    <InputSelect id="serialnumberid" @bind-Value="EquipmentOrder.SerialNumberId" class="form-control" disabled="@isSerialNumberIdDisabled">
                        <option value="">- Выберите -</option>
                        @foreach (var serialNumber in serialNumbers)
                        {
                            <option value="@serialNumber.Id">@serialNumber.Number</option>
                        }
                    </InputSelect>
                    <label for="serialnumberid" class="form-label">Серийный Номер:</label>
                    <ValidationMessage For="() => EquipmentOrder.SerialNumberId" class="text-danger" />
                </div>
               
                
                <div class="form-floating mb-3">
                    <InputSelect id="assigneeid" @bind-Value="EquipmentOrder.AssigneeId" class="form-control">
                        <option value="">- Выберите -</option>
                        @foreach (var user in applicationUsers)
                        {
                            <option value="@user.Id">@user.Name </option>
                        }
                    </InputSelect>
                    <label for="assigneeid" class="form-label">Ответственный:</label>
                    <ValidationMessage For="() => EquipmentOrder.AssigneeId" class="text-danger" />
                </div>
                
                <div class="form-floating mb-3">
                    <InputSelect id="locationid" @bind-Value="EquipmentOrder.LocationId" class="form-control">
                        <option value="">- Выберите -</option>
                        @foreach (var location in locations)
                        {
                            <option value="@location.Id">@location.Name </option>
                        }
                    </InputSelect>
                    <label for="locationid" class="form-label">Локация:</label>
                    <ValidationMessage For="() => EquipmentOrder.LocationId" class="text-danger" />
                </div>
               
                <div class="form-floating mb-3">
                    <InputDate id="ReceiptDate" @bind-Value="EquipmentOrder.ReceiptDate" class="form-control" disabled="@isReceiptDateDisabled" />
                    <label for="ReceiptDate" class="form-label">Дата получения:</label>
                    <ValidationMessage For="() => EquipmentOrder.ReceiptDate" class="text-danger" />
                </div>
               
                <div class="form-floating mb-3">
                    <InputDate id="ReturnDate" @bind-Value="EquipmentOrder.ReturnDate" class="form-control" disabled="@isReturnDateDisabled" />
                    <label for="ReturnDate" class="form-label">Дата возврата:</label>
                    <ValidationMessage For="() => EquipmentOrder.ReturnDate" class="text-danger" />
                </div>

                <AppInputFile Id="@EquipmentOrder.Id" />
                
                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">Сохранить</button> |
                    <a href="@($"equipmentorders/details?id={Id}")" title="Детали">Посмотреть</a> |
                    <a href="/equipmentorders">Назад к Списку</a>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery]
    private string? Id { get; set; }

    [SupplyParameterFromForm]
    private EquipmentOrder? EquipmentOrder { get; set; }

    private List<Equipment> equipment = new();
    private List<SerialNumber> serialNumbers = new();
    private List<Location> locations = new();
    private List<ApplicationUser> applicationUsers = new();
    private ApplicationUser? applicationUser;

    private bool    isEquipmentIdDisabled;
    private bool isSerialNumberIdDisabled;
    private bool    isReceiptDateDisabled;
    private bool     isReturnDateDisabled;

    protected override async Task OnInitializedAsync()
    {       
        if (Id is not null)
            EquipmentOrder ??= await Service.Get(Id, new EquipmentOrderIncludeParameters
                {
                    isIncludeAssignee = false,
                    isIncludeAuthor = true,
                    isIncludeEquipment = true,
                    isIncludeSerialNumber = true,
                    isIncludeLocation = false
                });

        if (EquipmentOrder is null)
            NavigationManager.NavigateTo("notfound");

        await GetEquipment();
        await GetSerialNumbers();
        await GetLocations();
        await GetApplicationUser();
        GetApplicationUsers();

        isEquipmentIdDisabled = EquipmentOrder?.EquipmentId != null;
        isSerialNumberIdDisabled = EquipmentOrder?.SerialNumberId != null;
        isReceiptDateDisabled = EquipmentOrder?.ReceiptDate != null;
        isReturnDateDisabled = EquipmentOrder?.ReturnDate != null;
    }

    private async Task GetEquipment()
    {
        equipment = await EquipmentService.GetListWithoutFolders();
    }

    private async Task GetSerialNumbers()
    {
        if (EquipmentOrder is null)
            return;

        var equipmentId = EquipmentOrder.EquipmentId;
        var result = await SerialNumberService.GetList(isIncludeEquipment: true, equipmentId: equipmentId, isNotAssignedOnly: false);
        if (result.IsSuccess)
            serialNumbers = result.Value;
    }

    private async Task GetLocations()
    {
        locations = await LocationService.GetList();
    }

    private async Task GetApplicationUser()
    {
        var authstate = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        applicationUser = await UserManager.GetUserAsync(authstate.User);
    }

    private void GetApplicationUsers()
    {
        applicationUsers = UserManager.Users.ToList();
    }

    private async Task UpdateEquipmentOrder()
    {
        await Service.Update(EquipmentOrder!);

        NavigationManager.NavigateTo("/equipmentorders");
    }
}
